# Database
DATABASE_URL="postgresql://user:password@localhost:5432/website_audit"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Server
PORT=3000

# CORS Configuration
# Set allowed origins (comma-separated for multiple origins, or * for all)
# Example: CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
CORS_ORIGIN=*

# Crawler Configuration
# Number of concurrent browsers in pool
BROWSER_COUNT=3

# Run browsers in headless mode (true for production)
HEADLESS=true

# Anti-Bot Detection Features
# Enable stealth mode (recommended for sites with bot detection)
STEALTH_MODE=true

# Enable human behavior simulation (mouse, scrolling, delays)
# WARNING: Makes crawling 2-5x slower but much more stealthy
HUMAN_BEHAVIOR=true

# Clerk Authentication (if using)
CLERK_SECRET_KEY=your_clerk_secret_key

# Environment
NODE_ENV=development

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
